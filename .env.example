# Copy to .env and fill in. Loaded automatically by food-app and food-cli on
# startup (via dotenvy). Real exported environment variables take precedence.
#
# Cloudflare AI Gateway (BYOK) creds for cookbook EPUB extraction. The base URL
# is the gateway ROOT (no provider suffix) — e.g.
# https://gateway.ai.cloudflare.com/v1/<account>/<gateway> — and each backend
# appends its own provider path (/anthropic, /openai, /google-ai-studio/…). The
# gateway injects each provider's API key, so no provider keys are needed here.
AI_GATEWAY_API_KEY=
CLOUDFLARE_AI_GATEWAY_BASE_URL=
