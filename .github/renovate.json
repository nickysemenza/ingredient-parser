{
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "egui",
      "matchPackageNames": [
        "eframe{/,}**",
        "egui{/,}**",
        "ehttp{/,}**"
      ]
    },
    {
      "groupName": "reqwest",
      "matchPackageNames": [
        "reqwest{/,}**"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "pin"
      ],
      "automergeType": "branch",
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "enabled": false
    }
  ]
}
