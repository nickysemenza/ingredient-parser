{
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 9am on monday"
  ],
  "prConcurrentLimit": 4,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "groupName": "egui",
      "matchPackageNames": [
        "eframe{/,}**",
        "egui{/,}**",
        "ehttp{/,}**"
      ]
    },
    {
      "groupName": "reqwest",
      "matchPackageNames": [
        "reqwest{/,}**"
      ]
    },
    {
      "groupName": "github-actions",
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "groupName": "demo-site js deps",
      "matchManagers": [
        "npm"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "pin"
      ],
      "automergeType": "branch",
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "enabled": false
    }
  ]
}
