// Rich-text accuracy corpus — instruction-prose counterpart to corpus.jsonl.
// Each row: { input, [ingredients], chunks: [ {text}|{measure:[..]}|{ing} ], [xfail] }.
// Committed rows must match RichParser output exactly; `xfail` rows are tolerated.
// Seeded by hand; harvest instruction lines via `scan-cookbooks` later.
{"input": "hello 1 cups foo bar", "chunks": [{"text": "hello "}, {"measure": [{"unit": "cup", "value": 1.0}]}, {"text": " foo bar"}]}
{"input": "makes 12 cookies", "chunks": [{"text": "makes "}, {"measure": [{"unit": "whole", "value": 12.0}]}, {"text": " cookies"}]}
{"input": "cut into 2-inch pieces", "chunks": [{"text": "cut into "}, {"measure": [{"unit": "inch", "value": 2.0}]}, {"text": " pieces"}]}
{"input": "at least 2 hours", "chunks": [{"text": "at least "}, {"measure": [{"unit": "hour", "value": 2.0}]}]}
{"input": "9\" x 13\"", "chunks": [{"measure": [{"unit": "\"", "value": 9.0}]}, {"text": " x "}, {"measure": [{"unit": "\"", "value": 13.0}]}]}
{"input": "bake at 350-375°F", "chunks": [{"text": "bake at "}, {"measure": [{"unit": "°f", "value": 350.0, "upper_value": 375.0}]}]}
{"input": "mix 2 cups flour and 1 tsp salt", "ingredients": ["flour", "salt"], "chunks": [{"text": "mix "}, {"measure": [{"unit": "cup", "value": 2.0}]}, {"text": " "}, {"ing": "flour"}, {"text": " and "}, {"measure": [{"unit": "tsp", "value": 1.0}]}, {"text": " "}, {"ing": "salt"}]}
{"input": "rest for 10 minutes", "chunks": [{"text": "rest for "}, {"measure": [{"unit": "minute", "value": 10.0}]}]}
{"input": "cook 2-3 hours", "chunks": [{"text": "cook "}, {"measure": [{"unit": "hour", "value": 2.0, "upper_value": 3.0}]}]}
{"input": "preheat oven to 350°F", "chunks": [{"text": "preheat oven to "}, {"measure": [{"unit": "°f", "value": 350.0}]}]}
{"input": "2 hours and up to 3 days", "chunks": [{"measure": [{"unit": "hour", "value": 2.0}]}, {"text": " and "}, {"measure": [{"unit": "day", "value": 0.0, "upper_value": 3.0}]}]}
{"input": "add 1 cup water and store for at most 2 days", "ingredients": ["water"], "chunks": [{"text": "add "}, {"measure": [{"unit": "cup", "value": 1.0}]}, {"text": " "}, {"ing": "water"}, {"text": " and store for "}, {"measure": [{"unit": "day", "value": 0.0, "upper_value": 2.0}]}]}
{"input": "1 Bring a large pot of water to a boil.", "chunks": [{"text": "1 Bring a large pot of water to a boil."}]}
{"input": "2 Set out 4 ramen bowls.", "chunks": [{"text": "2 Set out "}, {"measure": [{"unit": "whole", "value": 4.0}]}, {"text": " ramen bowls."}]}
{"input": "Toss with parsley.", "ingredients": ["flat-leaf parsley"], "chunks": [{"text": "Toss with "}, {"ing": "parsley"}, {"text": "."}]}
{"input": "Soak the sliced onion in cold water", "ingredients": ["red onion"], "chunks": [{"text": "Soak the sliced "}, {"ing": "onion"}, {"text": " in cold water"}]}
{"input": "dice the red onion", "ingredients": ["red onion"], "chunks": [{"text": "dice the "}, {"ing": "red onion"}]}
{"input": "broil until charred", "ingredients": ["oil"], "chunks": [{"text": "broil until charred"}]}
// Head-noun matching — more cases in the same vein.
// Multi-word head noun: "olive oil" variant wins over bare "oil".
{"input": "drizzle with olive oil", "ingredients": ["extra virgin olive oil"], "chunks": [{"text": "drizzle with "}, {"ing": "olive oil"}]}
// Bare last-word variant DOES fire on a real standalone word (complement to the broil/oil guard).
{"input": "brush with the oil", "ingredients": ["extra virgin olive oil"], "chunks": [{"text": "brush with the "}, {"ing": "oil"}]}
// Head noun at string start — leading edge counts as a boundary.
{"input": "parsley, chopped, for garnish", "ingredients": ["flat-leaf parsley"], "chunks": [{"ing": "parsley"}, {"text": ", chopped, for garnish"}]}
// Singular head noun mid-phrase ("egg whites" -> only "egg" highlighted).
{"input": "fold in the egg whites", "ingredients": ["egg"], "chunks": [{"text": "fold in the "}, {"ing": "egg"}, {"text": " whites"}]}
// Boundary guard: "ice" must not match inside "slice".
{"input": "slice the bread thinly", "ingredients": ["ice"], "chunks": [{"text": "slice the bread thinly"}]}
// Two names sharing a head noun both reduce to "onion"; one Ing emitted, harmless.
{"input": "dice the onion", "ingredients": ["red onion", "green onion"], "chunks": [{"text": "dice the "}, {"ing": "onion"}]}
// Measure and a head-noun mention coexist in one line.
{"input": "add 2 cups of the diced onion", "ingredients": ["red onion"], "chunks": [{"text": "add "}, {"measure": [{"unit": "cup", "value": 2.0}]}, {"text": " of the diced "}, {"ing": "onion"}]}
// Apostrophe counts as a boundary on the trailing side.
{"input": "trim the onion's root end", "ingredients": ["red onion"], "chunks": [{"text": "trim the "}, {"ing": "onion"}, {"text": "'s root end"}]}
// Full two-word name spelled out wins over its head-noun variant.
{"input": "combine the lemon juice and zest", "ingredients": ["lemon juice"], "chunks": [{"text": "combine the "}, {"ing": "lemon juice"}, {"text": " and zest"}]}
// A leading (non-head) word alone does NOT match — we strip suffixes, not prefixes.
{"input": "squeeze the lemon over top", "ingredients": ["lemon juice"], "chunks": [{"text": "squeeze the lemon over top"}]}
// Hyphenated full name matches verbatim.
{"input": "whisk the flat-leaf parsley in", "ingredients": ["flat-leaf parsley"], "chunks": [{"text": "whisk the "}, {"ing": "flat-leaf parsley"}, {"text": " in"}]}
// Plural/stemmed mention: prose "eggs" matches name "egg" (optional trailing s/es suffix); surface keeps the plural.
{"input": "beat the eggs", "ingredients": ["egg"], "chunks": [{"text": "beat the "}, {"ing": "eggs"}]}
// "es" plural form: name "tomato" matches prose "tomatoes".
{"input": "dice the tomatoes", "ingredients": ["tomato"], "chunks": [{"text": "dice the "}, {"ing": "tomatoes"}]}
// Plural suffix must re-check the boundary AFTER the suffix: "egg" must not punch through "eggplant".
{"input": "slice the eggplant", "ingredients": ["egg"], "chunks": [{"text": "slice the eggplant"}]}
// Same guard via the "s" branch: "lime"+"s" must not leak into "limestone".
{"input": "set on limestone", "ingredients": ["lime"], "chunks": [{"text": "set on limestone"}]}
// Apostrophe-s is a boundary, not a plural to absorb: surface stays "onion".
{"input": "trim the onion's stem", "ingredients": ["red onion"], "chunks": [{"text": "trim the "}, {"ing": "onion"}, {"text": "'s stem"}]}
// Case-sensitive guard: a capitalized mention mid-sentence stays text.
{"input": "the best Parsley around", "ingredients": ["flat-leaf parsley"], "chunks": [{"text": "the best Parsley around"}]}
// Sentence-initial capitalized head noun (guarded case-insensitive at chunk start).
{"input": "Parsley makes a nice garnish", "ingredients": ["flat-leaf parsley"], "chunks": [{"ing": "Parsley"}, {"text": " makes a nice garnish"}]}
// Imperative openers must not match even when an ingredient shares the verb spelling.
{"input": "Oil the pan over medium heat", "ingredients": ["olive oil"], "chunks": [{"text": "Oil the pan over medium heat"}]}
{"input": "Salt to taste before serving", "ingredients": ["salt"], "chunks": [{"text": "Salt to taste before serving"}]}
{"input": "Cream together the butter and sugar", "ingredients": ["heavy cream"], "chunks": [{"text": "Cream together the butter and sugar"}]}
// Mid-sentence amount + ingredient mention.
{"input": "After 5 minutes, stir in the parsley", "ingredients": ["flat-leaf parsley"], "chunks": [{"text": "After "}, {"measure": [{"unit": "minute", "value": 5.0}]}, {"text": ", stir in the "}, {"ing": "parsley"}]}
// Parenthetical aside stays prose.
{"input": "Roast (uncovered) for 20 minutes", "chunks": [{"text": "Roast (uncovered) for "}, {"measure": [{"unit": "minute", "value": 20.0}]}]}
// Plus-X-for-garnish pattern — garnish phrase stays text, ingredient highlighted.
{"input": "Top with parsley, plus more for garnish", "ingredients": ["flat-leaf parsley"], "chunks": [{"text": "Top with "}, {"ing": "parsley"}, {"text": ", plus more for garnish"}]}
// Multiple ingredient mentions in one step.
{"input": "Combine flour and salt, then add sugar", "ingredients": ["flour", "salt", "sugar"], "chunks": [{"text": "Combine "}, {"ing": "flour"}, {"text": " and "}, {"ing": "salt"}, {"text": ", then add "}, {"ing": "sugar"}]}
// Approximate duration with leading qualifier preserved as text.
{"input": "Simmer for about 15 minutes", "chunks": [{"text": "Simmer for about "}, {"measure": [{"unit": "minute", "value": 15.0}]}]}
// Temperature range in prose.
{"input": "Warm to 300-325°F", "chunks": [{"text": "Warm to "}, {"measure": [{"unit": "°f", "value": 300.0, "upper_value": 325.0}]}]}
// Ingredient at start of step after a numbered prefix (no highlight — not chunk start).
{"input": "3 Fold in the egg whites gently", "ingredients": ["egg"], "chunks": [{"text": "3 Fold in the "}, {"ing": "egg"}, {"text": " whites gently"}]}
// Second mention of same ingredient later in the line.
{"input": "Add onion, cook until soft, then add more onion", "ingredients": ["red onion"], "chunks": [{"text": "Add "}, {"ing": "onion"}, {"text": ", cook until soft, then add more "}, {"ing": "onion"}]}
// Semicolon-separated clauses with a measure in the second.
{"input": "Drain well; return to the pot and cook 2 minutes", "chunks": [{"text": "Drain well; return to the pot and cook "}, {"measure": [{"unit": "minute", "value": 2.0}]}]}
// Dimension in prose without falsely matching a unit-only ingredient name.
{"input": "Roll into 1-inch balls", "chunks": [{"text": "Roll into "}, {"measure": [{"unit": "inch", "value": 1.0}]}, {"text": " balls"}]}
// Garnish callout with ingredient mid-sentence.
{"input": "Serve hot, sprinkled with parsley", "ingredients": ["flat-leaf parsley"], "chunks": [{"text": "Serve hot, sprinkled with "}, {"ing": "parsley"}]}
